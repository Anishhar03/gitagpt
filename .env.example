# Local infrastructure. Compose service names are correct inside containers.
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://gitagpt:gitagpt@postgres:5432/gitagpt
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local defaults work without any external API key.
JWT_SECRET=replace-with-a-long-random-secret
AUTH_MODE=development
ADMIN_EMAILS=admin@gitagpt.local

# Production authentication.
GOOGLE_CLIENT_ID=

# Gemini primary and Groq fallback. Leave blank for deterministic local mode.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Runtime tuning.
WEB_CONCURRENCY=2
RATE_LIMIT_PER_MINUTE=20
RETRIEVAL_TOP_K=6
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
MAX_UPLOAD_BYTES=20971520
SEED_DEFAULT_DOCUMENT=true

# Frontend API location embedded during the web image build.
VITE_API_ORIGIN=http://localhost:8000
